# 浏览器配置 (edge | chrome)
BROWSER=edge
HEADLESS=true
BACKGROUND_WINDOW=true

# 主代理配置（留空则不使用）
PROXY=http://127.0.0.1:7897

# OTP 等待配置（秒）
OTP_WAIT_TIMEOUT=600
OTP_RESEND_WAIT_TIMEOUT=300
OTP_RECEIVE_ATTEMPTS=5
OTP_RESEND_MAX_ATTEMPTS=3
OTP_POLL_INTERVAL_SECONDS=5

# 邮箱服务配置
MAIL_PROVIDER=auto
MAIL_PROVIDER_ORDER=generator_email,tenminutemail,tempmail,awamail
GENERATOR_EMAIL_BASE_URL=https://generator.email
GENERATOR_EMAIL_PROXY=
GENERATOR_EMAIL_DOMAINS=
# 兼容旧命名（等价于 GENERATOR_EMAIL_DOMAINS）
GENERATOR_DOMAINS=
# 全量域名文件（每行一个域名，优先级高于上面的短列表）
GENERATOR_EMAIL_DOMAINS_FILE=data/generator_domains_full.txt
# 兼容旧命名（等价于 GENERATOR_EMAIL_DOMAINS_FILE）
GENERATOR_DOMAINS_FILE=data/generator_domains_full.txt
GENERATOR_EMAIL_DOMAIN_STRATEGY=random
GENERATOR_EMAIL_DOMAIN_KEYWORDS=mail,com,inbox
GENERATOR_EMAIL_ENUMERATE_ALL_DOMAINS=false
GENERATOR_EMAIL_DOMAIN_ENUM_QUERIES=
GENERATOR_EMAIL_DOMAIN_ENUM_SAVE_PATH=output/generator-email-domains.txt
GENERATOR_EMAIL_MAX_CREATE_RETRIES=12
GENERATOR_EMAIL_POLL_INTERVAL_SECONDS=4
TENMINUTEMAIL_BASE_URL=https://10minutemail.com
TENMINUTEMAIL_BOOTSTRAP_PATH=/
TENMINUTEMAIL_PROXY=
TENMINUTEMAIL_POLL_INTERVAL_SECONDS=5
TEMPMAIL_BASE_URL=https://temp-mail.app
TEMPMAIL_PART=main
TEMPMAIL_EXPIRE_MINUTES=1440
TEMPMAIL_PROXY=
AWAMAIL_BASE_URL=https://awamail.com
AWAMAIL_PROXY=

# Outlook Email API（可选，只有 MAIL_PROVIDER=outlookapi 时需要）
OUTLOOK_EMAIL_BASE_URL=http://127.0.0.1:5000
OUTLOOK_EMAIL_AUTH_MODE=auto
OUTLOOK_EMAIL_API_KEY=5b220a92d7057e7864xxxxxxxxxx
OUTLOOK_EMAIL_LOGIN_PASSWORD=xxxxxxxxxx
OUTLOOK_EMAIL_GROUP_ID=
OUTLOOK_EMAIL_ADDRESS_MODE=aliases-first
OUTLOOK_EMAIL_ADDRESS_POOL=
OUTLOOK_EMAIL_FOLDER=all
OUTLOOK_EMAIL_FETCH_TOP=10
OUTLOOK_EMAIL_DISABLE_USED_ACCOUNTS=true
OUTLOOK_EMAIL_DISABLE_USED_STATUS=inactive
OUTLOOK_EMAIL_USED_ADDRESSES_PATH=output/outlook-email-used-addresses.json
